# ===========================================
# ChemSafe Water Monitor - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# -------------------------------------------
# AI PROVIDERS — CHEMSAFE ROLES
# -------------------------------------------

# DeepSeek — PRIMARY: runs the conversational interview agent
# Required. Without this, the guided interview will not work.
# Get key: https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Gemini — PRIMARY: image analysis only (pipe material identification)
# Required. Without this, photo uploads in the interview will fail
# gracefully (falls back to proxy questions) but won't analyse images.
# IMPORTANT: Use a key with Gemini 1.5 Flash access enabled.
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# -------------------------------------------
# AI PROVIDERS — FAILOVER CHAIN (optional)
# -------------------------------------------
# These are used automatically if DeepSeek is unavailable.
# Priority order (after DeepSeek): OpenRouter → OpenAI → Anthropic → Kimi
# Leave blank if you don't have keys — the router skips missing providers.

# OpenRouter — cheapest failover, supports Llama and Mistral models
OPENROUTER_API_KEY=your_openrouter_api_key

# OpenAI — fallback text provider
OPENAI_API_KEY=your_openai_api_key

# Anthropic — fallback text provider
ANTHROPIC_API_KEY=your_anthropic_api_key

# Kimi (Moonshot) — fallback text provider
MOONSHOT_API_KEY=your_kimi_api_key

# -------------------------------------------
# NOTE ON VITE_ PREFIXED AI KEYS
# -------------------------------------------
# ChemSafe does NOT use client-side AI calls — all AI runs server-side.
# Do not add VITE_DEEPSEEK_API_KEY or VITE_GEMINI_API_KEY here.
# The ai-router.ts reads server-side env vars only (no VITE_ prefix).

# -------------------------------------------
# DATABASE
# -------------------------------------------
DATABASE_URL=your_postgres_connection_string

# -------------------------------------------
# APP CONFIGURATION
# -------------------------------------------
NODE_ENV=development
SESSION_SECRET=your_session_secret_here
