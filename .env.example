# ===========================================
# ChemSafe Water Monitor — Local Environment
# ===========================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the values below (DEEPSEEK and GEMINI are the only required ones)
# 3. Run:  pnpm install --no-frozen-lockfile && pnpm run db:push && pnpm run dev

# -------------------------------------------
# DATABASE — required
# -------------------------------------------
# Local Postgres: create a DB and paste the URL here.
# Example (default local Postgres): postgresql://postgres:password@localhost:5432/chemsafe
DATABASE_URL=postgresql://postgres:password@localhost:5432/chemsafe

# -------------------------------------------
# AI PROVIDERS — primary (both required for full functionality)
# -------------------------------------------

# DeepSeek — runs the conversational interview agent
# Get key: https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk-your_deepseek_key_here

# Gemini — image analysis only (pipe material identification from photos)
# Get key: https://aistudio.google.com/app/apikey  (free tier, no billing needed)
GEMINI_API_KEY=AIza-your_gemini_key_here

# -------------------------------------------
# AI PROVIDERS — failover chain (all optional)
# -------------------------------------------
# Used automatically if DeepSeek is unavailable.
# Priority: OpenRouter → OpenAI → Anthropic → Kimi
# Leave blank to skip a provider.

OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MOONSHOT_API_KEY=

# -------------------------------------------
# SERVER
# -------------------------------------------
NODE_ENV=development
SESSION_SECRET=change-me-to-a-random-string-in-production

# API server port (default: 8080 if not set)
PORT=8080
