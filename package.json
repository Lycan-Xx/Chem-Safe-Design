{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently --names \"api,web\" --prefix-colors \"cyan,green\" \"pnpm --filter @workspace/api-server run dev\" \"pnpm --filter @workspace/chemsafe run dev\"",
    "db:push": "pnpm --filter @workspace/db run push",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
